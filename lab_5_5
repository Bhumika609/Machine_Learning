from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
import pandas as pd
import numpy as np
import os
from sklearn.metrics import silhouette_score,calinski_harabasz_score,davies_bouldin_score
extract_path = r"C:\Users\BHUMIKA\OneDrive\文件\ML_Project\mental_workload_detection\data_processed\features"
all_data=[]
for root,dirs,files in os.walk(extract_path):
    for file in files:
        if file.endswith(".xlsx") or file.endswith(".xls"):
            file_path=os.path.join(root, file)
            df=pd.read_excel(file_path)
            all_data.append(df)
data=pd.concat(all_data,ignore_index=True)
X=data.iloc[:,:-1].values
scaler=StandardScaler()
X_scaled=scaler.fit_transform(X)
k_means=KMeans(n_clusters=2,random_state=0,n_init="auto")
k_means.fit(X_scaled)
cluster_labels=k_means.labels_
cluster_centers=k_means.cluster_centers_
print("The first 20 labels",cluster_labels[:20])
print("The cluster centers are",cluster_centers)
ss=silhouette_score(X_scaled,cluster_labels)
chs=calinski_harabasz_score(X_scaled,cluster_labels)
dbs=davies_bouldin_score(X_scaled,cluster_labels)
print("The silhoutte score is",ss)
print("The calinski harabasz score is",chs)
print("The davies bouldin score is",dbs)